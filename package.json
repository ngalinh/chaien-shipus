{
  "name": "chaien-shipus",
  "version": "1.0.0",
  "description": "Vietnamese shipping customer management system",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"node server.js\" \"vite client --port 5173\"",
    "postinstall": "npm --prefix client install --include=dev && npm --prefix client run build && cp client/dist/index.html client/dist/manifest.json . && rm -rf assets && cp -r client/dist/assets ."
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
